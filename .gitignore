# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Byte-compiled / optimized / DLL files
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environment
venv/
env/
ENV/
.vscode/

